<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ГдеСвета</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="app">
        <header>
            <h1>📅 ГдеСвета</h1>
            <button id="menuBtn">☰</button>
        </header>
        <nav id="nav">
            <button class="active" data-page="calendar">Календарь</button>
            <button data-page="clients">Клиенты</button>
            <button data-page="stats">Статистика</button>
        </nav>
        <main id="main">
            <p>Загрузка...</p>
        </main>
    </div>
    <!-- Кнопка вынесена за #app -->
    <button id="addAppBtnFixed" class="add-btn-fixed">+ Добавить запись</button>
    <script src="app.js"></script>
</body>
</html>
